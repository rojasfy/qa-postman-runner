PORT=3000

JENKINS_BASE_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_API_TOKEN=REEMPLAZAR_CON_API_TOKEN_REAL
JENKINS_POLL_INTERVAL_MS=1500
JSON_BODY_LIMIT=75mb

# URL alcanzable por Jenkins para publicar live progress al backend.
# Si Jenkins corre en Docker sobre Windows, usa la IP del host o host.docker.internal si aplica.
JENKINS_DASHBOARD_BASE_URL=http://<IP_DE_TU_HOST>:3000

# FASE 7: job Jenkins unico y parametrizado para los modulos activos.
REGRESIVOS_JOB_NAME=REGRESIVOS-MODULAR

# Postman compartido por todos los modulos.
POSTMAN_COLLECTION_FILE=collections/REGRESIVOS.postman_collection.json
POSTMAN_ENVIRONMENT_FILE=environments/PRE-UAT-PROD-CLAROVIDEO.postman_environment.json

# Store temporal en memoria. Al reiniciar el backend se reinicia el historial.
RUN_STORE_LIMIT_PER_MODULE=50
